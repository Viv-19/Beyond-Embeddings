  "description": "Node.js/Express backend for the BeyondEmbeddings research blog — handles auth, content CRUD, and comment management via a PostgreSQL database.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
